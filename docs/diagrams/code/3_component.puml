@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Container_Boundary(api, "Transaction Orchestrator") {

    Component(controller, "TransactionController", "REST", "Receives requests")
    Component(aspect, "IdempotencyAspect", "AOP", "Intercepts requests & handles Redis cache")
    Component(service, "TransactionService", "Application", "Orchestrates business flow")
    Component(factory, "PaymentProviderFactory", "Application", "Creates provider instances")
    Component(adapter, "ProviderAdapter", "Adapter", "Calls external APIs")

}

System_Ext(provider, "Payment Provider")
System_Ext(redis, "Redis")
System_Ext(db, "PostgreSQL")

Rel(controller, aspect, "Intercepted by")
Rel(aspect, redis, "Checks/Stores key")
Rel(aspect, controller, "Proceeds to")
Rel(controller, service, "Calls")
Rel(service, db, "Reads/Writes")
Rel(service, factory, "Requests provider")
Rel(factory, adapter, "Returns")
Rel(adapter, provider, "HTTP")

@enduml
